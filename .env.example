# Botón Rojo Environment Configuration
# Copy this to .env and fill in your actual values

# Database Configuration
DB_NAME=odoo_br_pilot
DB_USER=odoo
DB_PASSWORD=change_me_to_strong_password
DB_HOST=db
DB_PORT=5432

# Odoo Configuration
ODOO_PORT=8069
ADMIN_PASSWORD=change_me_to_strong_admin_password

# MercadoPago Configuration
# Get these from https://www.mercadopago.com.ar/developers/panel
# These can also be set via the Odoo UI at: Botón Rojo → Integración MP
MP_SELLER_ID=
MP_ACCESS_TOKEN=
MP_CLIENT_ID=
MP_CLIENT_SECRET=

# Application Environment
ENVIRONMENT=sandbox
DEBUG=0
LOG_LEVEL=info

# Optional: Docker Hub credentials for pushing images
DOCKER_USERNAME=
DOCKER_PASSWORD=
