<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <record id="seq_br_dispute" model="ir.sequence">
      <field name="name">Disputa BR</field>
      <field name="code">br.dispute</field>
      <field name="prefix">DISP-</field>
      <field name="padding">4</field>
      <field name="number_next">1</field>
      <field name="number_increment">1</field>
    </record>

    <record id="cron_br_dispute_sla" model="ir.cron">
      <field name="name">BR Disputas — check SLA 42h</field>
      <field name="model_id" ref="model_br_dispute"/>
      <field name="state">code</field>
      <field name="code">model.cron_check_sla()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">hours</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
    </record>

  </data>
</odoo>
