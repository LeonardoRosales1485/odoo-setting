<?xml version="1.0" encoding="utf-8"?>
<odoo>

  <record id="view_br_liquidation_form" model="ir.ui.view">
    <field name="name">br.liquidation.form</field>
    <field name="model">br.liquidation</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_confirmar" string="Confirmar"
            type="object" class="btn-primary"
            invisible="estado != 'borrador'"/>
          <button name="action_transferir" string="Marcar transferida"
            type="object" class="btn-primary"
            invisible="estado != 'confirmada'"/>
          <field name="estado" widget="statusbar" statusbar_visible="borrador,confirmada,transferida"/>
        </header>
        <sheet>
          <div class="oe_title">
            <h1><field name="name" readonly="1"/></h1>
          </div>
          <group>
            <group>
              <field name="fecha"/>
              <field name="cantidad_ordenes" readonly="1"/>
            </group>
            <group>
              <field name="total_amount" readonly="1"/>
            </group>
          </group>
          <notebook>
            <page string="Líneas">
              <field name="linea_ids">
                <tree editable="bottom">
                  <field name="proveedor_id"/>
                  <field name="cantidad_ordenes"/>
                  <field name="monto_proveedor"/>
                  <field name="estado_transferencia"/>
                </tree>
                <form>
                  <sheet>
                    <group>
                      <field name="proveedor_id"/>
                      <field name="cbu" readonly="1"/>
                      <field name="cantidad_ordenes"/>
                      <field name="monto_proveedor"/>
                      <field name="estado_transferencia"/>
                    </group>
                    <group>
                      <field name="orden_ids" widget="many2many_tags"/>
                    </group>
                  </sheet>
                </form>
              </field>
            </page>
            <page string="Notas">
              <field name="notas"/>
            </page>
          </notebook>
        </sheet>
      </form>
    </field>
  </record>

  <record id="view_br_liquidation_list" model="ir.ui.view">
    <field name="name">br.liquidation.list</field>
    <field name="model">br.liquidation</field>
    <field name="arch" type="xml">
      <tree>
        <field name="name"/>
        <field name="fecha"/>
        <field name="cantidad_ordenes"/>
        <field name="total_amount"/>
        <field name="estado" widget="badge"
          decoration-info="estado == 'borrador'"
          decoration-warning="estado == 'confirmada'"
          decoration-success="estado == 'transferida'"/>
      </tree>
    </field>
  </record>

  <record id="action_br_liquidation" model="ir.actions.act_window">
    <field name="name">Liquidaciones</field>
    <field name="res_model">br.liquidation</field>
    <field name="view_mode">list,form</field>
  </record>

</odoo>
