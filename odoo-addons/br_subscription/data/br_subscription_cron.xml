<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <data noupdate="1">

    <record id="seq_br_subscription" model="ir.sequence">
      <field name="name">Suscripción BR</field>
      <field name="code">br.subscription</field>
      <field name="prefix">SUB-</field>
      <field name="padding">4</field>
      <field name="number_next">1</field>
      <field name="number_increment">1</field>
    </record>

    <record id="cron_br_renovar_suscripciones" model="ir.cron">
      <field name="name">BR Renovar suscripciones vencidas</field>
      <field name="model_id" ref="model_br_subscription"/>
      <field name="state">code</field>
      <field name="code">model.cron_renovar_suscripciones()</field>
      <field name="interval_number">1</field>
      <field name="interval_type">days</field>
      <field name="numbercall">-1</field>
      <field name="active">True</field>
    </record>

  </data>
</odoo>
